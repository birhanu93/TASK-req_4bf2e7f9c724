{
    "name": "eaglepoint/workforce-hub",
    "description": "Workforce Training & Operations Hub",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "symfony/dependency-injection": "^6.4",
        "symfony/event-dispatcher": "^6.4",
        "symfony/http-foundation": "^6.4",
        "symfony/http-kernel": "^6.4",
        "symfony/routing": "^6.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "audit": {
            "ignore": ["PKSA-5jz8-6tcw-pbk4"]
        }
    }
}
