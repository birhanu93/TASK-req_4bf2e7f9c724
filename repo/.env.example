# Copy to .env for local development. Do not commit secrets.

# Database (PDO MySQL). Prefer a single DSN in production; the parts below are
# used when DB_DSN is unset.
#DB_DSN=mysql:host=127.0.0.1;port=3306;dbname=workforce;charset=utf8mb4
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=workforce
DB_USER=workforce
DB_PASS=workforce

# Boot-time connect policy for PDO. The kernel retries transient errors and
# fails fast with a descriptive error after the last attempt.
DB_CONNECT_RETRIES=5
DB_CONNECT_RETRY_MS=200

# Storage root for certificates, uploaded files, snapshots, and the KEK.
# The tiering service also creates `hot`, `cold`, `certs-cold`, and
# `uploads-cold` directories here for its named stores.
STORAGE_ROOT=./storage

# Override the location of the AES-256-GCM key encryption key. The KEK is a
# 32-byte file, generated automatically on first run with 0600 permissions.
# Rotate by replacing this file out of band and restarting.
KEK_PATH=./storage/keys/kek.bin

# Session cookie. Set to false only for plain-HTTP local development;
# production deployments MUST leave this true (the default).
SESSION_COOKIE_SECURE=true

# Frontend: base URL of the backend API (used by Vite proxy). Leave unset for
# same-origin deployments.
VITE_API_BASE=http://localhost:8080
